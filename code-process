#Added skill extraction with improved matching

import re

skills_db = {
    "python": ["python"],
    "machine learning": ["machine learning", "ml"],
    "sql": ["sql"],
    "nlp": ["nlp", "natural language processing"]
}

def extract_skills(text):
    found = []

    for skill, variations in skills_db.items():
        for v in variations:
            if re.search(r'\b' + re.escape(v) + r'\b', text):
                found.append(skill)
                break

    return found
skills = extract_skills(resume_clean)
print("Skills:", skills)

